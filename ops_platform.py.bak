def get_revenue_dashboard():
    orders = ldb("orders")
    leads = ldb("leads")
    rev = ldb("revenue_log")
    today = datetime.now().strftime("%Y-%m-%d")
    this_month = datetime.now().strftime("%Y-%m")
    
    total_revenue = sum(r.get("amount",0) for r in rev.values())
    today_revenue = sum(r.get("amount",0) for r in rev.values() if r.get("date","")[:10]==today)
    month_revenue = sum(r.get("amount",0) for r in rev.values() if r.get("date","")[:7]==this_month)
    
    by_product = {}
    by_channel = {}
    by_circle = {}
    for r in rev.values():
        p = r.get("product","other")
        ch = r.get("channel","direct")
        amt = r.get("amount",0)
        by_product[p] = by_product.get(p,0) + amt
        by_channel[ch] = by_channel.get(ch,0) + amt
    
    # Daily revenue last 30 days
    daily = {}
    for r in rev.values():
        d = r.get("date","")[:10]
        if d: daily[d] = daily.get(d,0) + r.get("amount",0)
    
    return {
        "total_revenue": total_revenue,
        "today_revenue": today_revenue,
        "month_revenue": month_revenue,
        "total_orders": len(orders),
        "total_leads": len(leads),
        "conversion": round(len(orders)/max(len(leads),1)*100,1),
        "by_product": by_product,
        "by_channel": by_channel,
        "daily": dict(sorted(daily.items())[-30:]),
        "mrr": month_revenue,
    }

def get_product_dashboard():
    orders = ldb("orders")
    result = []
    for pid, p in PRODUCTS.items():
        porders = [o for o in orders.values() if o.get("product")==pid]
        rev = sum(o.get("amount",0) for o in porders)
        active = sum(1 for o in porders.values() if o.get("state") not in ["cancelled",""])
        result.append({
            "id": pid,
            "name": p["name"],
            "icon": p["icon"],
            "circle": p["circle"],
            "price": p["price"],
            "status": p["status"],
            "orders": len(porders),
            "active": active,
            "revenue": rev,
            "profit": round(rev * (1 - p["cost_pct"]), 1),
        })
    return result
"""
MediSlim 中央管理平台
统一管理：内容发布 / 用户CRM / 订单管理 / 数据分析 / 多平台对接
"""
import os
import json
import uuid
import time
from datetime import datetime, timedelta
from pathlib import Path
from http.server import HTTPServer, BaseHTTPRequestHandler
import urllib.parse

DATA_DIR = Path("./data")
DATA_DIR.mkdir(exist_ok=True)

def load_db(name):
    f = DATA_DIR / f"{name}.json"
    return json.loads(f.read_text()) if f.exists() else {}

def save_db(name, data):
    (DATA_DIR / f"{name}.json").write_text(json.dumps(data, ensure_ascii=False, indent=2))

def now():
    return datetime.now().isoformat()

def gen_id():
    return str(uuid.uuid4())[:12]

